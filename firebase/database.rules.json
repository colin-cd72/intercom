{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": true,

        "info": {
          ".write": "!data.exists() || data.child('createdBy').val() == auth.uid",
          ".validate": "newData.hasChildren(['name', 'createdBy', 'createdAt'])"
        },

        "presence": {
          "$userId": {
            ".write": "auth != null && auth.uid == $userId",
            ".validate": "newData.hasChildren(['displayName', 'timestamp'])"
          }
        },

        "inbox": {
          "$userId": {
            ".read": "auth != null && auth.uid == $userId",
            ".write": "auth != null && root.child('rooms').child($roomId).child('presence').child(auth.uid).exists()"
          }
        },

        "channels": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('presence').child(auth.uid).exists()"
        },

        "signaling": {
          "$fromUser": {
            "$toUser": {
              ".read": "auth != null && auth.uid == $toUser",
              ".write": "auth != null && auth.uid == $fromUser"
            }
          }
        },

        "ice": {
          "$fromUser": {
            "$toUser": {
              ".read": "auth != null && auth.uid == $toUser",
              ".write": "auth != null && auth.uid == $fromUser"
            }
          }
        }
      }
    }
  }
}
